{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Characters",
  "type": "object",
  "required": ["book_title", "characters"],
  "properties": {
    "book_title": { "type": "string" },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "character_id",
          "name",
          "role",
          "surface_goal",
          "deep_desire",
          "public_mask",
          "private_wound",
          "core_contradiction",
          "speech_style",
          "habit_echo",
          "competence",
          "blind_spots",
          "wrong_beliefs",
          "relationship_edges",
          "forbidden_behaviors"
        ],
        "properties": {
          "character_id": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" },
          "surface_goal": { "type": "string" },
          "deep_desire": { "type": "string" },
          "public_mask": { "type": "string" },
          "private_wound": { "type": "string" },
          "core_contradiction": { "type": "string" },
          "speech_style": { "type": "string" },
          "habit_echo": {
            "type": "array",
            "items": { "type": "string" }
          },
          "competence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blind_spots": {
            "type": "array",
            "items": { "type": "string" }
          },
          "wrong_beliefs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relationship_edges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["target", "relation", "tension"],
              "properties": {
                "target": { "type": "string" },
                "relation": { "type": "string" },
                "tension": { "type": "string" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "forbidden_behaviors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
